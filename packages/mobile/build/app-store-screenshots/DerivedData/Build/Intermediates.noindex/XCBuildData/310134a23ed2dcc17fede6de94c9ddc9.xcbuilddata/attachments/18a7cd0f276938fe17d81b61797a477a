#!/bin/sh
# Resolve dSYM source path mappings for prebuilt xcframeworks
# This script is auto-generated by expo-modules-autolinking
#
# Writes UUID plists into dSYMs so lldb can remap
# /expo-src/... paths back to local package paths.

STAMP_FILE="$DERIVED_FILE_DIR/expo-dsym-resolve-ExpoModulesWorklets-$CONFIGURATION.stamp"

# Find dSYMs inside the xcframework (all slices)
XCFW_PATH="$PODS_ROOT/ExpoModulesWorklets/ExpoModulesWorklets.xcframework"

if [ -d "$XCFW_PATH" ]; then
  FOUND_DSYM=0
  for DSYM_DIR in "$XCFW_PATH"/*/dSYMs; do
    if [ -d "$DSYM_DIR/ExpoModulesWorklets.framework.dSYM" ]; then
      if [ $FOUND_DSYM -eq 0 ]; then
        . "$REACT_NATIVE_PATH/scripts/xcode/with-environment.sh"
        FOUND_DSYM=1
      fi
      "$NODE_BINARY" "$PODS_ROOT/../../../../node_modules/expo-modules-autolinking/scripts/ios/resolve-dsym-sourcemaps.js" \
        -d "$DSYM_DIR" \
        -m "ExpoModulesWorklets" \
        -n "expo-modules-core" \
        -r "$PODS_ROOT/../../node_modules/expo-modules-core"
    fi
  done
fi

# Touch stamp file for Xcode dependency tracking
mkdir -p "$(dirname "$STAMP_FILE")"
touch "$STAMP_FILE"

